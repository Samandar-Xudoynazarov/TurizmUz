# Backend manzil (faqat rasm/static URL lar uchun)
# Local devda ko'pincha: http://localhost:8081
VITE_BACKEND_URL=http://10.113.31.105:8081

# Dev paytida API proxy target (Vite server o‘qiydi)
# Agar qo'ymasangiz, vite.config.ts avtomatik VITE_BACKEND_URL yoki localhost:8081 ni oladi
VITE_API_PROXY_TARGET=http://localhost:8081

# ✅ Deploy (Netlify) uchun API base url:
# - Local dev: /api (Vite proxy ishlaydi)
# - Deploy: https://YOUR_BACKEND_DOMAIN/api
VITE_API_BASE_URL=/api
