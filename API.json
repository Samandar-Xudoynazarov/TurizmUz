          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) pm.environment.set('ACCESS_TOKEN', json.accessToken);",
                  "  if (json && json.refreshToken) pm.environment.set('REFRESH_TOKEN', json.refreshToken);",
                  "} catch (e) {}"
